# App
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Database: no vars needed here. Production gets INSTANCE_CONNECTION_NAME/DB_USER/DB_NAME
# injected automatically by Apps Platform. For local dev against the real DB, see the
# `apps-platform app connect-db` instructions in README.md instead of setting these in .env.local.

# Email (optional — console fallback if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cheers from Applied <no-reply@applied.co>

# Workday (optional — gift balance display only)
WORKDAY_API_URL=
WORKDAY_API_TOKEN=
